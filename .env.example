# Optional overrides only. A standard Docker Compose install works without this file.

WEBSITE_PORT=8090
BASE_URL=http://localhost:8090
# SECRET_KEY is auto-generated and persisted under /app/data/.session_secret if omitted.
SECRET_KEY=
# ADMIN_EMAIL and ADMIN_PASSWORD are optional bootstrap credentials.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ALLOWED_HOSTS=localhost,127.0.0.1

# Security settings - CRITICAL for production
SESSION_COOKIE_SECURE=false  # Set to true behind HTTPS
GITHUB_URL=https://github.com/antybubbs/kaya
DEMO_URL=/demo
KAYA_VERSION=v0.19.1

# 2FA Configuration
ENABLE_2FA=true
REQUIRE_2FA=false  # Set to true to enforce 2FA for all admin users

# Rate Limiting & Account Lockout
MAX_LOGIN_ATTEMPTS=5
RATE_LIMIT_WINDOW=300  # seconds (5 minutes)
ACCOUNT_LOCKOUT_DURATION=900  # seconds (15 minutes)

# Session Management
SESSION_TIMEOUT=3600  # seconds (1 hour)

# CORS Configuration (restrict in production)
CORS_ORIGINS=*  # Set to specific domains in production
